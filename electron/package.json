{
  "name": "freya",
  "version": "1.2.0",
  "description": "Freya — PDF Read-Aloud desktop app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.freya.app",
    "productName": "Freya",
    "icon": "assets/icon.ico",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "../backend/dist/freya-backend/",
        "to": "backend",
        "filter": ["**/*"]
      },
      {
        "from": "../frontend/dist/",
        "to": "frontend",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Freya"
    }
  }
}
